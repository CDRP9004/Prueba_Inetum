# --- Scraper (Fase 2) ---
SCRAPER_BASE_URL=https://www.bbva.mx
SCRAPER_SITEMAP_URL=https://www.bbva.mx/sitemap.xml
# Prefijos de ruta a incluir, en orden de prioridad (separados por coma)
SCRAPER_SECTIONS=/personas/,/empresas/
# Máximo de páginas a descargar en una corrida (control de alcance/tiempo)
SCRAPER_MAX_PAGES=150
# Segundos de espera entre requests (buenas prácticas de scraping)
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_USER_AGENT=PruebaRAG-BBVA-Bot/1.0 (+contacto: crystyan.davyd@gmail.com; proyecto educativo/prueba tecnica)
SCRAPER_RAW_DIR=data/raw

# --- Limpieza (Fase 3) ---
CLEANING_PROCESSED_DIR=data/processed
# Páginas cuyo texto limpio quede por debajo de este umbral se descartan (ruido/errores)
CLEANING_MIN_TEXT_LENGTH=200

# --- Indexación vectorial (Fase 4) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
# Modelo de embeddings multilingüe, liviano y gratuito (corre en CPU)
EMBEDDING_MODEL=intfloat/multilingual-e5-small
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=bbva_docs

# --- Pipeline RAG (Fase 5) ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
# Cantidad de chunks recuperados por pregunta
RAG_TOP_K=5

# --- Historial de conversación (Fase 7) ---
HISTORY_DB_PATH=data/history.db
# Cantidad de mensajes previos (usuario + asistente) usados como contexto por sesión
HISTORY_WINDOW_N=6

# --- Retrieval híbrido + MMR (Fase 9) ---
# Combina búsqueda densa (embeddings) + BM25 (léxica) vía Reciprocal Rank Fusion,
# y diversifica el top-k final con MMR para no repetir chunks casi idénticos.
USE_HYBRID_SEARCH=true
RRF_K=60
# 0 = solo prioriza diversidad, 1 = solo prioriza relevancia a la pregunta
MMR_LAMBDA=0.5
# Cuántos candidatos de más se recuperan (top_k * este valor) antes de fusionar/diversificar
RETRIEVAL_CANDIDATE_MULTIPLIER=4

# --- Reranker (Fase 10) ---
USE_RERANKER=true
# Cross-encoder multilingüe (incluye español vía mMARCO), liviano, corre en CPU
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
# Cuántos candidatos de más se recuperan (top_k * este valor) antes de rerankear y recortar
RERANK_CANDIDATE_MULTIPLIER=3

# --- Las siguientes secciones se irán completando en fases posteriores ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
